# AI Fitness Coach Configuration
# Copy this file to ../.env and adjust as needed.

# Path to the SQLite database (default: data/fitness.db)
# AFC_DB_PATH=./data/fitness.db

# Path to your profile JSON (default: config/profile.json)
# AFC_PROFILE_PATH=./config/profile.json

# Path to the exercise database (default: src/exercises.md)
# AFC_EXERCISES_PATH=./src/exercises.md

# Your timezone (used for cron job reminders)
# AFC_TIMEZONE=America/New_York

# WhatsApp group chat ID (for automated reminders)
# AFC_WHATSAPP_CHAT_ID=your-group-id@g.us
